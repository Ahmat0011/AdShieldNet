<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
	<application android:allowBackup="true" android:icon="@mipmap/appicon" android:roundIcon="@mipmap/appicon_round" android:supportsRtl="true">
		<!--
		    Explicit service declaration required so the manifest merger can attach
		    android:foregroundServiceType="connectedDevice", which is mandatory on
		    Android 14+ (API 34) for any service started with startForegroundService().
		    The name must match the Java class name produced by the [Register] attribute
		    on AdShieldVpnService.
		-->
		<service
			android:name="com.companyname.adshieldnet.AdShieldVpnService"
			android:exported="true"
			android:permission="android.permission.BIND_VPN_SERVICE"
			android:foregroundServiceType="connectedDevice">
			<intent-filter>
				<action android:name="android.net.VpnService" />
			</intent-filter>
		</service>
	</application>
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
	<!--
	    Required by Android 13+ (API 33) for foregroundServiceType="connectedDevice".
	    Silently ignored on older OS versions.
	-->
	<uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
	<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
</manifest>
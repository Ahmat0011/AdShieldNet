## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bin/
obj/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml

# Build results of Microsoft.NET.Sdk.Functions
bin/
obj/

# Package Management
packages/
*.nupkg
# Don't ignore packages for projects that use PackageReference
!**/packages/build/
!**/packages/tools/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
appsettings.json
appsettings.Development.json
appsettings.Production.json

# Visual Studio Code
.vscode/

# Rider
.idea/

# Android
*.apk
*.aab
*.dex
*.keystore

# iOS
*.app
*.ipa
*.dsym

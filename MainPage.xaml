<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AdShieldNet.MainPage"
             BackgroundColor="#121212">

    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="30">
        
        <Label Text="AdShield Pro" FontSize="36" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
        
        <Label x:Name="StatusLabel" Text="Schutz ist inaktiv" TextColor="#aaaaaa" FontSize="18" HorizontalOptions="Center" />
        
        <Button x:Name="ToggleVpnButton" 
                Text="Schutz starten" 
                BackgroundColor="#28a745" 
                TextColor="White" 
                FontSize="20" 
                FontAttributes="Bold" 
                CornerRadius="25" 
                HeightRequest="60" 
                WidthRequest="250" 
                Clicked="OnToggleVpnClicked" 
                HorizontalOptions="Center" />
                
        <Label x:Name="BlockedAdsLabel" Text="Blockierte Werbung: 0" TextColor="#aaaaaa" FontSize="16" HorizontalOptions="Center" />
        
    </VerticalStackLayout>
</ContentPage>
